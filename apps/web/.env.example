# Next.js / web app – copy to .env.local and fill in values.
# See also root .env.example for full project variables.

# App URL (for Auth.js callbacks)
NEXTAUTH_URL=http://localhost:3000

# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/briefforge

# Auth.js (required for sign-in)
AUTH_SECRET=change-me-min-32-chars

# Redis / BullMQ (required for indexing jobs)
REDIS_URL=redis://localhost:6379

# OpenAI (required for embeddings and chat; set BRIEFFORGE_DISABLE_LLM=1 to skip API calls)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_STRICT_MODEL=gpt-4.1

# Optional: disable LLM calls (stub responses, no API cost)
BRIEFFORGE_DISABLE_LLM=0

# Optional: token for local evals (packages/evals calling /api/qa/ask, /api/briefs/generate)
BRIEFFORGE_EVAL_TOKEN=
