# Core app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/briefforge

# Supabase (optional for local, required for hosted)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth.js
AUTH_SECRET=change-me-in-prod
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# OpenAI / LLM provider
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_STRICT_MODEL=gpt-4.1

# Observability / env
LOG_LEVEL=info
BRIEFFORGE_ENV=local
BRIEFFORGE_EVAL_TOKEN=some-long-random-string
BRIEFFORGE_DISABLE_LLM=0

# Absolute or relative path for file storage (default: ./storage)
STORAGE_ROOT=
